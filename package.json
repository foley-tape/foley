{
  "name": "foley",
  "version": "0.1.0",
  "private": true,
  "description": "A lo-fi tape instrument for your coding agents. 纯本地、零遥测。First deck: TAPE·ZERO.",
  "type": "module",
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/foley-tape/foley.git" },
  "homepage": "https://github.com/foley-tape/foley#readme",
  "files": [
    "cli",
    "engine",
    "adapters",
    "protocol",
    "sound",
    "!sound/records/*.mp3",
    "!sound/assets/*.wav",
    "stage",
    "!stage/tools",
    "!stage/fixtures/**",
    "!stage/assets/paper.png",
    "params.json",
    "verdict.json",
    "sweep.json",
    "sound-params.json",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=23.6"
  },
  "scripts": {
    "scan": "node cli/index.ts scan",
    "replay": "node cli/index.ts replay",
    "live": "node cli/index.ts live",
    "probe": "node cli/index.ts probe",
    "typecheck": "tsc --noEmit",
    "test": "node --test \"golden/**/*.test.ts\"",
    "test:producer-atf": "node --test golden/producer-lifecycle.atf.test.ts golden/producer-lifecycle.integration.atf.test.ts",
    "test:wo4-atf": "node --test golden/zero-session-first-minute.atf.test.ts",
    "runs": "node cli/index.ts runs",
    "ear": "node cli/index.ts ear",
    "hunt": "node cli/index.ts hunt",
    "sync:readme": "node scripts/sync-readme.mjs",
    "check:media": "node scripts/check-heavy-media.mjs",
    "check:pack": "node scripts/check-pack-budget.mjs",
    "check:writeback": "node scripts/check-ledger-writeback.mjs",
    "prepublishOnly": "node scripts/sync-readme.mjs --check && node scripts/check-pack-budget.mjs && node scripts/check-ledger-writeback.mjs --strict && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "undici-types": "^6.21.0"
  },
  "keywords": ["cli", "claude", "coding-agent", "tape", "observability", "lo-fi", "tui", "session-replay"],
  "author": "foley-tape",
  "bin": {
    "foley": "cli/index.ts"
  }
}
